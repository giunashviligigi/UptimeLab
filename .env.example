# PostgreSQL
POSTGRES_USER=uptime
POSTGRES_PASSWORD=uptime_secret
POSTGRES_DB=uptimelab
POSTGRES_PORT=5432

# Backend (.NET API)
BACKEND_PORT=5001
JWT_SECRET=CHANGE_ME_use_a_long_random_secret_at_least_32_characters

# Frontend (Next.js) — must match how browsers reach the API
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5001

# Elastic APM (make elastic-up / make up-all) — set on backend automatically in compose
# ELASTIC_APM_SERVER_URL=http://apm-server:8200
# ELASTIC_APM_SERVICE_NAME=uptimelab-api
